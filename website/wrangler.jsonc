{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "yuraive-website",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-16",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "none",
  },
  "routes": [
    {
      "pattern": "yuraive.com",
      "custom_domain": true,
    },
  ],
}
