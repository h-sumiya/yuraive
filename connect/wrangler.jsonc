{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "yuraive-connect",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-16",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
