<Application
    x:Class="Yuraive.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="SystemAccentColor">#FF574DE5</Color>
            <SolidColorBrush x:Key="PlayerSurfaceBrush" Color="#101116" />
            <SolidColorBrush x:Key="PlayerCardBrush" Color="#23232C" />
            <SolidColorBrush x:Key="PlayerMutedBrush" Color="#B2AFBA" />
            <SolidColorBrush x:Key="PlayerAccentBrush" Color="#574DE5" />
            <SolidColorBrush x:Key="PlayerAccentContainerBrush" Color="#2B284F" />
            <SolidColorBrush x:Key="PlayerAccentLowBrush" Color="#25574DE5" />

            <!-- WinUI's stock controls otherwise keep the Windows system accent. -->
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#574DE5" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#D9574DE5" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#A6574DE5" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#574DE5" />
            <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#D9574DE5" />

            <Style x:Key="RoundIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="44" />
                <Setter Property="Height" Value="44" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style x:Key="PlayerIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="50" />
                <Setter Property="Height" Value="50" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="#16FFFFFF" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style x:Key="PlayerPillButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="48" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Background" Value="#16FFFFFF" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style x:Key="SettingsChoiceButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="112" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>
            <Style x:Key="SettingsLinkButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="52" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>
            <Style x:Key="LibraryGridItemStyle" TargetType="GridViewItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="6" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="IsTabStop" Value="True" />
            </Style>
            <DataTemplate x:Key="InspectionTreeNodeTemplate">
                <ContentPresenter Content="{Binding Content}" HorizontalContentAlignment="Stretch" />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
