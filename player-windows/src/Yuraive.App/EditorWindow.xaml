<Window
    x:Class="Yuraive.App.EditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="#14191E">
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Background="#1A2026">
            <StackPanel Margin="16,0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                <Image Width="27" Height="27" Source="ms-appx:///Assets/YuraiveMark.svg" Stretch="Uniform" />
                <TextBlock x:Name="TitleText" VerticalAlignment="Center" Foreground="#E8EDF1" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <WebView2 x:Name="EditorWebView" DefaultBackgroundColor="#14191E" />
            <ProgressRing x:Name="LoadingIndicator" Width="38" Height="38" IsActive="True" Foreground="#7E78EE" />
            <InfoBar x:Name="ErrorBar" Margin="16" VerticalAlignment="Top" Severity="Error" IsClosable="False" IsOpen="False" />
        </Grid>
    </Grid>
</Window>
