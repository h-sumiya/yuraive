<script>
  const INTRO_DURATION = 12_700
  const NODE_DURATION = 620
  const TERMINAL_DURATION = 980
  const EDGE_DURATION = 820

  const runForActiveTime = (
    flow: HTMLElement,
    duration: number,
    onProgress?: (progress: number) => void,
  ) =>
    new Promise<boolean>((resolve) => {
      let elapsed = 0
      let previous = performance.now()

      const tick = (now: number) => {
        if (!flow.isConnected) {
          resolve(false)
          return
        }

        const delta = Math.min(now - previous, 50)
        previous = now

        if (!flow.classList.contains('is-paused') && !document.hidden) {
          const speed = Math.max(0.1, Number(flow.dataset.playbackSpeed) || 1)
          elapsed += delta * speed
          onProgress?.(Math.min(elapsed / duration, 1))
        }

        if (elapsed >= duration) {
          resolve(true)
          return
        }

        requestAnimationFrame(tick)
      }

      requestAnimationFrame(tick)
    })

  const setActiveNode = (flow: HTMLElement, node: string) => {
    flow.querySelectorAll<SVGGElement>('[data-media]').forEach((frame) => {
      frame.classList.toggle('is-active', frame.dataset.media === node)
    })
    flow.querySelectorAll<SVGGElement>('[data-node]').forEach((graphNode) => {
      graphNode.classList.toggle('is-active', graphNode.dataset.node === node)
    })
    flow.dataset.currentNode = node
    flow.dispatchEvent(new CustomEvent('yuraive:node', { detail: { node } }))
  }

  const playNode = async (flow: HTMLElement, node: string, duration = NODE_DURATION) => {
    const progress = flow.querySelector<SVGPathElement>('.player-progress')
    const orb = flow.querySelector<SVGGElement>('.play-orb')

    orb?.classList.remove('is-visible')
    setActiveNode(flow, node)
    if (progress) progress.style.transform = 'scaleX(0)'

    return runForActiveTime(flow, duration, (value) => {
      if (progress) progress.style.transform = `scaleX(${value})`
    })
  }

  const travelRoute = async (flow: HTMLElement, route: string) => {
    const path = flow.querySelector<SVGPathElement>(`.bubble-path[data-route="${route}"]`)
    const orb = flow.querySelector<SVGGElement>('.play-orb')
    if (!path || !orb) return false

    flow.querySelectorAll<SVGPathElement>('.bubble-path').forEach((candidate) => {
      candidate.classList.toggle('is-active', candidate === path)
    })
    flow.querySelectorAll<SVGGElement>('[data-weight-route]').forEach((weight) => {
      weight.classList.toggle('is-active', weight.dataset.weightRoute === route)
    })

    const history = (flow.dataset.routeHistory ?? '').split(',').filter(Boolean)
    history.push(route)
    flow.dataset.routeHistory = history.slice(-32).join(',')
    flow.dataset.currentRoute = route
    flow.dispatchEvent(
      new CustomEvent('yuraive:route', {
        detail: {
          route,
          from: path.dataset.from,
          to: path.dataset.to,
          weight: Number(path.dataset.weight ?? 0),
        },
      }),
    )

    const length = path.getTotalLength()
    const placeOrb = (progress: number) => {
      const eased =
        progress < 0.5 ? 2 * progress * progress : 1 - Math.pow(-2 * progress + 2, 2) / 2
      const point = path.getPointAtLength(length * eased)
      orb.setAttribute('transform', `translate(${point.x} ${point.y})`)
    }

    placeOrb(0)
    orb.classList.add('is-visible')
    const completed = await runForActiveTime(flow, EDGE_DURATION, placeOrb)
    placeOrb(1)
    orb.classList.remove('is-visible')
    path.classList.remove('is-active')
    flow.querySelectorAll<SVGGElement>('[data-weight-route]').forEach((weight) => {
      weight.classList.remove('is-active')
    })
    delete flow.dataset.currentRoute
    return completed
  }

  const restartIntro = (flow: HTMLElement) => {
    flow.querySelectorAll<SVGPathElement>('.bubble-path').forEach((path) => {
      path.classList.remove('is-active')
    })
    flow.querySelectorAll<SVGGElement>('[data-weight-route], [data-node]').forEach((item) => {
      item.classList.remove('is-active')
    })
    flow.querySelectorAll<SVGGElement>('[data-media]').forEach((frame) => {
      frame.classList.toggle('is-active', frame.dataset.media === '1')
    })

    const orb = flow.querySelector<SVGGElement>('[data-play-orb]')
    orb?.classList.remove('is-visible')
    orb?.removeAttribute('transform')

    const progress = flow.querySelector<SVGPathElement>('[data-player-progress]')
    if (progress) progress.style.transform = 'scaleX(0)'

    delete flow.dataset.currentNode
    delete flow.dataset.currentRoute
    delete flow.dataset.lastDecision
    delete flow.dataset.lastRoll
    flow.dataset.phase = 'intro'

    flow.classList.add('is-resetting')
    void flow.offsetWidth
    flow.classList.remove('is-resetting')
    void flow.offsetWidth
    flow.dispatchEvent(new CustomEvent('yuraive:story-restart'))
  }

  const runRandomPlayback = async (flow: HTMLElement) => {
    while (flow.isConnected) {
      if (!(await runForActiveTime(flow, INTRO_DURATION))) return
      flow.dataset.phase = 'playback'
      flow.dispatchEvent(new CustomEvent('yuraive:playback-ready'))

      if (!(await playNode(flow, '1'))) return
      if (!(await travelRoute(flow, '1-2'))) return
      if (!(await playNode(flow, '2'))) return

      let forceFirstLoop = true
      let terminalReached = false
      while (!terminalReached && flow.isConnected) {
        const candidates = [...flow.querySelectorAll<SVGPathElement>('.bubble-path[data-from="2"]')]
        let randomValue: number | null = null
        let selected: SVGPathElement | undefined

        if (forceFirstLoop) {
          selected =
            flow.querySelector<SVGPathElement>('.bubble-path[data-route="2-3"]') ??
            candidates.at(-1)
          forceFirstLoop = false
        } else {
          const totalWeight = candidates.reduce(
            (total, candidate) => total + Number(candidate.dataset.weight ?? 0),
            0,
          )
          randomValue = Math.random()
          let remaining = randomValue * totalWeight
          selected = candidates.at(-1)

          for (const candidate of candidates) {
            remaining -= Number(candidate.dataset.weight ?? 0)
            if (remaining < 0) {
              selected = candidate
              break
            }
          }
        }

        const nextNode = selected?.dataset.to ?? '4'
        const branch = selected?.dataset.route ?? `2-${nextNode}`
        flow.dataset.lastDecision = branch
        flow.dataset.lastRoll = randomValue === null ? 'forced' : String(randomValue)
        flow.dispatchEvent(
          new CustomEvent('yuraive:decision', {
            detail: { route: branch, roll: randomValue, forced: randomValue === null },
          }),
        )

        if (!(await travelRoute(flow, branch))) return
        if (
          !(await playNode(flow, nextNode, nextNode === '4' ? TERMINAL_DURATION : NODE_DURATION))
        ) {
          return
        }

        if (nextNode === '4') {
          terminalReached = true
          const completedRuns = Number(flow.dataset.completedRuns ?? 0) + 1
          flow.dataset.completedRuns = String(completedRuns)
          flow.dispatchEvent(new CustomEvent('yuraive:complete', { detail: { completedRuns } }))
          restartIntro(flow)
        } else {
          if (!(await travelRoute(flow, '3-2'))) return
          if (!(await playNode(flow, '2'))) return
        }
      }
    }
  }

  const setupYuraiveFlows = () => {
    document.querySelectorAll<HTMLElement>('[data-yuraive-flow]').forEach((flow) => {
      if (flow.dataset.ready === 'true') return

      const button = flow.querySelector<HTMLButtonElement>('.flow-toggle')
      flow.dataset.ready = 'true'

      button?.addEventListener('click', () => {
        const paused = flow.classList.toggle('is-paused')
        button.setAttribute(
          'aria-label',
          paused ? 'アニメーションを再生' : 'アニメーションを一時停止',
        )
      })

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        flow.dataset.phase = 'reduced'
      } else {
        flow.dataset.phase = 'intro'
        void runRandomPlayback(flow)
      }
    })
  }

  setupYuraiveFlows()
  document.addEventListener('astro:page-load', setupYuraiveFlows)
</script>

