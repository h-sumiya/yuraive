{
  "name": "yuraive-editor",
  "private": true,
  "version": "0.0.0",
  "description": "Visual editor for Yuraive content graphs",
  "homepage": "https://editor.yuraive.com/",
  "type": "module",
  "scripts": {
    "wasm:build": "wasm-pack build ../runtime --target web --out-dir ../editor/src/wasm/yuraive-runtime --out-name yuraive_runtime --release",
    "dev": "npm run wasm:build && vite",
    "build": "npm run wasm:build && tsc -b && vite build",
    "lint": "npm run wasm:build && oxlint --ignore-pattern 'src/wasm/**'",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wasm-pack": "^0.15.0"
  }
}
