{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "yuraive-editor",
  "compatibility_date": "2026-07-16",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "routes": [
    {
      "pattern": "editor.yuraive.com",
      "custom_domain": true,
    },
  ],
}
